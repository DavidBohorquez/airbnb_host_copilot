# Copy to .env (repo root) and fill in. .env is gitignored — never commit real keys.

# LLM provider: ollama | anthropic | openai
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1

# API keys (only needed for the matching provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local Ollama server
OLLAMA_HOST=http://localhost:11434

# Embeddings
EMBED_MODEL=intfloat/multilingual-e5-small

# Paths (relative to repo root)
DATA_DIR=data_airbnb_bordeaux
ARTIFACTS_DIR=artifacts
CHROMA_DIR=artifacts/chroma

# Retrieval
TOP_K=8